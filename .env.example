DATABASE_URL=sqlite:///./house_crawler.db
MAX_PAGES=20
LOG_LEVEL=INFO

# Home Assistant webhook — leave blank to disable notifications
HA_WEBHOOK_URL=
# Fraction below comparable median to trigger alert (default: 0.15 = 15% cheaper)
HA_DEAL_THRESHOLD=0.15
# Minimum house size in m² to consider (default: 60)
HA_MIN_SIZE_M2=60
